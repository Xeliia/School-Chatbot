# === LLM Backend Configuration ===
# Backend type: "ollama" | "llamacpp" | "gemini" | "openai" | "openai_compatible"
LLM_BACKEND_TYPE=ollama

# ─── Ollama Setup (default) ───
# URL and model auto-detected — only set if you changed defaults
# LLM_BACKEND_URL=http://localhost:11434
# LLM_MODEL=llama3.2
# Examples: ollama pull llama3.2 | ollama pull mistral | ollama pull phi3

# ─── llama.cpp Setup (for AMD GPUs with ROCm) ───
# LLM_BACKEND_TYPE=llamacpp
# LLM_BACKEND_URL=http://localhost:8080
# LLM_MODEL=local-model

# ─── Google Gemini Setup ───
# LLM_BACKEND_TYPE=gemini
# LLM_API_KEY=your-gemini-api-key
# LLM_MODEL=gemini-2.0-flash
# Get your key at: https://aistudio.google.com/apikey

# ─── OpenAI Setup ───
# LLM_BACKEND_TYPE=openai
# LLM_API_KEY=your-openai-api-key
# LLM_MODEL=gpt-4o-mini

# ─── Any OpenAI-Compatible API (OpenRouter, Together, etc.) ───
# LLM_BACKEND_TYPE=openai_compatible
# LLM_BACKEND_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your-api-key
# LLM_MODEL=meta-llama/llama-3-8b-instruct

# === API Security ===
# Must match VITE_API_KEY in frontend/.env
# NOTE: This is not a secret key. It's only used for simple frontend-backend authentication and can be anything. In production, it's much wiser to use a long string of characters and numbers.
API_KEY=your-secret-key-here

# === Server Settings ===
HOST=0.0.0.0
PORT=8000

# === Frontend URL (for CORS) ===
FRONTEND_URL=http://localhost:5173

# === Character / System Prompt ===
# Can be a filename in backend/prompts/ folder OR inline text
# Available prompts: noa.txt (default)
# Create your own: backend/prompts/yourcharacter.txt
SYSTEM_PROMPT=noa.txt

# Or use inline prompt:
# SYSTEM_PROMPT=You are a helpful assistant named Alice. Be friendly and concise.

# === Generation Parameters ===
# Tune these for your model - lower values = more predictable
TEMPERATURE=0.8        # Creativity (0.1-1.5). Lower for weak models.
MAX_TOKENS=256         # Max response length. Keep low for weak models.
TOP_P=0.9              # Nucleus sampling
REPEAT_PENALTY=1.1     # Local backends only (ollama/llamacpp). Prevents repetition.
# FREQUENCY_PENALTY=0.0  # Cloud backends only. Alternative to repeat_penalty.
# PRESENCE_PENALTY=0.0   # Cloud backends only.

# ─── Recommended settings by model size ───
# Weak models (<7B params): TEMPERATURE=0.6, MAX_TOKENS=150
# Medium models (7B-13B):   TEMPERATURE=0.8, MAX_TOKENS=256
# Strong models (>30B):     TEMPERATURE=0.9, MAX_TOKENS=512
# Cloud models (Gemini/GPT): TEMPERATURE=0.8, MAX_TOKENS=512
