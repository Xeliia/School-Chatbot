# === Frontend Configuration ===
# ⚠️ IMPORTANT: Copy this file to .env before running the frontend!
#    cp .env.example .env

# Backend API URL — must match where the backend is running
VITE_API_URL=http://localhost:8000

# API Key — must match the API_KEY in the root .env
# NOTE THIS IS NOT A SECRET KEY. It's only used for simple frontend-backend authentication and can be anything. In production, its much wiser to use a long strings of characters and number
VITE_API_KEY=your-api-key-here

# ─── Remote / Tunnel Access ───
# When exposing the backend via ngrok or similar:
# VITE_API_URL=https://xxxx-xxxx.ngrok-free.app
